{
  "name": "yasm",
  "displayName": "YASM",
  "description": "View disassembly side-by-side with C/C++ source code",
  "version": "0.1.0",
  "publisher": "yasm",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "workspaceContains:.yasm.json",
    "onCommand:yasm.diffAssembly",
    "onCommand:yasm.liveMode"
  ],
  "main": "./bin/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yasm.showAssembly",
        "title": "YASM: Show Assembly"
      },
      {
        "command": "yasm.refresh",
        "title": "YASM: Refresh Disassembly"
      },
      {
        "command": "yasm.initConfig",
        "title": "YASM: Initialize Config"
      },
      {
        "command": "yasm.diffAssembly",
        "title": "YASM: Diff Assembly"
      },
      {
        "command": "yasm.liveMode",
        "title": "YASM: Live Mode"
      }
    ],
    "configuration": {
      "title": "YASM",
      "properties": {}
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outdir=bin --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outdir=bin --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "^4.3.7",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.76.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "@vscode/l10n-dev": "^0.0.18",
    "esbuild": "^0.20.0",
    "eslint": "^8.36.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.5",
    "vsce": "^2.15.0",
    "vscode-extension-tester": "^8.7.0",
    "webpack": "^5.76.3",
    "webpack-cli": "^5.0.1"
  }
}
